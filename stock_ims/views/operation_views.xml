        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-success="state == 'done'">
                <field name="name" string="Reference"/>
                <field name="location_id" string="From"/>
                <field name="location_dest_id" string="To"/>
                <field name="scheduled_date" string="Schedule date"/>
                <field name="state" string="Status" widget="badge"/>
                <button name="action_ims_validate" string="Validate" type="object" class="btn-primary" invisible="state != 'assigned'"/>
            </list>
