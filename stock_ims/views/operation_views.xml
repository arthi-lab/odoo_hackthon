    <!-- Stock Adjustments Action -->
    <record id="action_ims_inventory_adjustment" model="ir.actions.act_window">
        <field name="name">Inventory Adjustments</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
