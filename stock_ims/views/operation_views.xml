<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Receipts Specialized List View -->
    <record id="view_picking_tree_ims_receipts" model="ir.ui.view">
        <field name="name">stock.picking.tree.ims.receipts</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-success="state == 'done'">
                <field name="name" string="Reference"/>
                <field name="location_id" string="From"/>
                <field name="location_dest_id" string="To"/>
                <field name="partner_id" string="Contact"/>
                <field name="scheduled_date" string="Schedule date"/>
                <field name="state" string="Status" widget="badge" decoration-success="state == 'assigned'" decoration-info="state == 'draft'"/>
                <button name="action_ims_validate" string="Validate" type="object" class="btn-primary" invisible="state != 'assigned'"/>
            </list>
        </field>
    </record>

    <!-- Receipts Action -->
    <record id="action_ims_receipts" model="ir.actions.act_window">
        <field name="name">Receipts</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('picking_type_code', '=', 'incoming')]</field>
        <field name="context">{'default_picking_type_code': 'incoming'}</field>
        <field name="view_id" ref="view_picking_tree_ims_receipts"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Receipt
            </p>
        </field>
    </record>

    <!-- 2. Delivery Specialized List View -->
    <record id="view_picking_tree_ims_deliveries" model="ir.ui.view">
        <field name="name">stock.picking.tree.ims.deliveries</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-success="state == 'done'">
                <field name="name" string="Reference"/>
                <field name="location_id" string="From"/>
                <field name="location_dest_id" string="To"/>
                <field name="partner_id" string="Contact"/>
                <field name="scheduled_date" string="Schedule date"/>
                <field name="state" string="Status" widget="badge" decoration-success="state == 'assigned'" decoration-info="state == 'draft'"/>
                <button name="action_ims_validate" string="Validate" type="object" class="btn-primary" invisible="state != 'assigned'"/>
            </list>
        </field>
    </record>

    <!-- Delivery Action -->
    <record id="action_ims_deliveries" model="ir.actions.act_window">
        <field name="name">Delivery</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('picking_type_code', '=', 'outgoing')]</field>
        <field name="context">{'default_picking_type_code': 'outgoing'}</field>
        <field name="view_id" ref="view_picking_tree_ims_deliveries"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Delivery
            </p>
        </field>
    </record>

