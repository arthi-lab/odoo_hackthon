<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Categories Menu Action -->
    <record id="action_ims_product_category" model="ir.actions.act_window">
        <field name="name">Product Categories</field>
        <field name="res_model">product.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new product category
            </p>
        </field>
    </record>
    <!-- Products Menu Action -->
    <record id="action_ims_product_template" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_filter_to_sell': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new product
            </p>
        </field>
    </record>

    <!-- Reordering Rules Menu Action -->
    <record id="action_ims_orderpoint" model="ir.actions.act_window">
        <field name="name">Reordering Rules</field>
        <field name="res_model">stock.warehouse.orderpoint</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define reordering rules for your products
            </p>
        </field>
    </record>
</odoo>
